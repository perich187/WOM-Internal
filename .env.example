# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — used in /api serverless functions (never expose in frontend)
# Get from: supabase.com → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Meta (Facebook + Instagram) ───────────────────────────────────────────────
# Get from: developers.facebook.com → Your App → Settings → Basic
VITE_META_APP_ID=your-meta-app-id-here        # safe to expose (used in OAuth URL)
META_APP_SECRET=your-meta-app-secret-here     # server-only — NEVER commit this

# ── App URL ───────────────────────────────────────────────────────────────────
# Your deployed Vercel URL — must match the OAuth redirect URI registered in Meta
# e.g. https://wom-internal.vercel.app
VITE_APP_URL=https://your-app.vercel.app
